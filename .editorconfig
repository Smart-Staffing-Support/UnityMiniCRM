# EditorConfig v0.17.2
# https://spec.editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_size = 4
indent_style = space

# NOTE: Non-standard option
max_line_length = 79

[*.md]
trim_trailing_whitespace = false

[*.{py,toml}]
indent_size = 4

[*.{html,css,js,jsx,json,vue}]
indent_size = 2
